@* ProjectList.razor - Displays projects loaded from the API *@
@using SkillSnap.Client.Models
@using SkillSnap.Client.Services
@inject ProjectService ProjectService
@inject UserSessionService Session

<div class="project-list">
    <div class="section-header">
        <h3>Projects</h3>
        <p>Explore recent works and share your portfolio highlights.</p>
    </div>

    @if (projects is null)
    {
        <p>Loading project cards...</p>
    }
    else if (!projects.Any())
    {
        <p class="text-muted">No projects have been added yet.</p>
    }
    else
    {
        @foreach (var project in projects)
        {
            <div class="project-card">
                <img src="@project.ImageUrl" alt="@project.Title" />
                <h4>@project.Title</h4>
                <p>@project.Description</p>
            </div>
        }
    }

    @if (Session.IsAdmin)
    {
        <div class="form-card">
            <h4>Add Project</h4>
            <div class="form-group">
                <label for="project-title">Title</label>
                <input id="project-title" placeholder="Project title" @bind="newProject.Title" />
            </div>
            <div class="form-group">
                <label for="project-description">Description</label>
                <input id="project-description" placeholder="Short description" @bind="newProject.Description" />
            </div>
            <div class="form-group">
                <label for="project-image">Image URL</label>
                <input id="project-image" placeholder="https://..." @bind="newProject.ImageUrl" />
            </div>
            <button class="btn btn-primary" type="button" @onclick="HandleAdd">Add Project</button>
        </div>
    }
    else
    {
        <p class="text-muted">Log in as an admin to add projects.</p>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="error-text">@errorMessage</p>
    }
</div>

@code {
    private List<Project>? projects;
    private Project newProject = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += StateHasChanged;
        projects = await ProjectService.GetProjectsAsync();
    }

    private async Task HandleAdd()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newProject.Title) || string.IsNullOrWhiteSpace(newProject.Description))
        {
            errorMessage = "Title and description are required.";
            return;
        }

        var added = await ProjectService.AddProjectAsync(newProject);
        if (!added)
        {
            errorMessage = "Could not add project. Log in again if your session is expired.";
            return;
        }

        newProject = new();
        projects = await ProjectService.GetProjectsAsync();
    }
}
