@* ProjectList.razor - Displays projects loaded from the API *@
@using SkillSnap.Client.Models
@using SkillSnap.Client.Services
@inject ProjectService ProjectService
@inject UserSessionService Session

<div class="project-list">
    <div class="section-header">
        <h3>Projects</h3>
        <p>Explore recent works and share your portfolio highlights.</p>
    </div>

    @if (projects is null)
    {
        <p>Loading project cards...</p>
    }
    else if (!projects.Any())
    {
        <p class="text-muted">No projects have been added yet.</p>
    }
    else
    {
        @foreach (var project in projects)
        {
            <div class="project-card">
                @if (editingId == project.Id)
                {
                    <div class="form-group">
                        <label>Title</label>
                        <input @bind="editDraft!.Title" placeholder="Title" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <input @bind="editDraft!.Description" placeholder="Description" />
                    </div>
                    <div class="form-group">
                        <label>Image URL</label>
                        <input @bind="editDraft!.ImageUrl" placeholder="https://..." />
                    </div>
                    <div class="action-row">
                        <button class="btn btn-primary btn-sm" @onclick="() => SaveEdit(project.Id)">Save</button>
                        <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="error-text">@errorMessage</p>
                    }
                }
                else
                {
                    <img src="@project.ImageUrl" alt="@project.Title" />
                    <h4>@project.Title</h4>
                    <p>@project.Description</p>
                    @if (Session.IsAdmin)
                    {
                        <div class="action-row">
                            <button class="btn btn-secondary btn-sm" @onclick="() => StartEdit(project)">Edit</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteProject(project.Id)">Delete</button>
                        </div>
                    }
                }
            </div>
        }
    }

    @if (Session.IsAdmin)
    {
        <AddProject OnProjectAdded="RefreshProjects" />
    }
    else
    {
        <p class="text-muted">Log in as an admin to add projects.</p>
    }
</div>

@code {
    private List<Project>? projects;
    private int? editingId;
    private Project? editDraft;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += StateHasChanged;
        projects = await ProjectService.GetProjectsAsync();
    }

    private async Task RefreshProjects()
    {
        projects = await ProjectService.GetProjectsAsync();
    }

    private void StartEdit(Project project)
    {
        editingId = project.Id;
        editDraft = new Project
        {
            Id = project.Id,
            Title = project.Title,
            Description = project.Description,
            ImageUrl = project.ImageUrl,
            PortfolioUserId = project.PortfolioUserId
        };
        errorMessage = null;
    }

    private void CancelEdit()
    {
        editingId = null;
        editDraft = null;
        errorMessage = null;
    }

    private async Task SaveEdit(int id)
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(editDraft?.Title) || string.IsNullOrWhiteSpace(editDraft?.Description))
        {
            errorMessage = "Title and description are required.";
            return;
        }

        var ok = await ProjectService.UpdateProjectAsync(id, editDraft!);
        if (!ok)
        {
            errorMessage = "Could not update project. Check your session.";
            return;
        }

        CancelEdit();
        projects = await ProjectService.GetProjectsAsync();
    }

    private async Task DeleteProject(int id)
    {
        var ok = await ProjectService.DeleteProjectAsync(id);
        if (ok)
            projects = await ProjectService.GetProjectsAsync();
    }
}
