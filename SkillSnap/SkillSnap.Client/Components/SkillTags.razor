@* SkillTags.razor - Displays skills loaded from the API in a tag-style list *@
@using SkillSnap.Client.Models
@using SkillSnap.Client.Services
@inject SkillService SkillService
@inject UserSessionService Session

<div class="skill-tags">
    <div class="section-header">
        <h3>Skills</h3>
        <p>Highlight key abilities and keep the portfolio skills list fresh.</p>
    </div>

    @if (skills is null)
    {
        <p>Loading skills...</p>
    }
    else if (!skills.Any())
    {
        <p class="text-muted">No skills have been added yet.</p>
    }
    else
    {
        <ul>
            @foreach (var skill in skills)
            {
                <li class="skill-tag">
                    <span class="skill-name">@skill.Name</span>
                    <span class="skill-level">@skill.Level</span>
                </li>
            }
        </ul>
    }

    @if (Session.IsAdmin)
    {
        <div class="form-card">
            <h4>Add Skill</h4>
            <div class="form-group">
                <label for="skill-name">Name</label>
                <input id="skill-name" placeholder="Skill name" @bind="newSkill.Name" />
            </div>
            <div class="form-group">
                <label for="skill-level">Level</label>
                <input id="skill-level" placeholder="e.g. Expert" @bind="newSkill.Level" />
            </div>
            <button class="btn btn-primary" type="button" @onclick="HandleAdd">Add Skill</button>
        </div>
    }
    else
    {
        <p class="text-muted">Log in as an admin to add skills.</p>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="error-text">@errorMessage</p>
    }
</div>

@code {
    private List<Skill>? skills;
    private Skill newSkill = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += StateHasChanged;
        skills = await SkillService.GetSkillsAsync();
    }

    private async Task HandleAdd()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newSkill.Name) || string.IsNullOrWhiteSpace(newSkill.Level))
        {
            errorMessage = "Name and level are required.";
            return;
        }

        var added = await SkillService.AddSkillAsync(newSkill);
        if (!added)
        {
            errorMessage = "Could not add skill. Log in again if your session is expired.";
            return;
        }

        newSkill = new();
        skills = await SkillService.GetSkillsAsync();
    }
}
