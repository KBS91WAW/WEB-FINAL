@page "/register"
@using SkillSnap.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Create your account</h2>
            <p>Start managing your portfolio with a secure login.</p>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="@(messageColor == "red" ? "error-text" : "text-muted")">@message</p>
        }

        <div class="form-group">
            <label for="register-email">Email</label>
            <input id="register-email" type="email" @bind="email" placeholder="you@example.com" />
        </div>
        <div class="form-group">
            <label for="register-password">Password</label>
            <input id="register-password" type="password" @bind="password" placeholder="Choose a password" />
        </div>

        <button class="btn btn-primary" @onclick="HandleRegister">Register</button>
        <div style="margin-top: 1rem;">
            <a href="/login">Already have an account? Login</a>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string message = string.Empty;
    private string messageColor = "green";

    private async Task HandleRegister()
    {
        message = string.Empty;
        var success = await AuthService.RegisterAsync(email, password);
        if (success)
        {
            message = "Registration successful! You can now log in.";
            messageColor = "green";
        }
        else
        {
            message = "Registration failed. Check your email and password requirements.";
            messageColor = "red";
        }
    }
}
